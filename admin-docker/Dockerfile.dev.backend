# Development Dockerfile for Admin Backend
FROM python:3.13-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends curl && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy package files and harmony directory structure for install
COPY pyproject.toml README.md ./
COPY harmony/__init__.py harmony/__init__.py
ENV SETUPTOOLS_SCM_PRETEND_VERSION=0.1.0
RUN pip install --no-cache-dir -e ".[admin,elasticsearch]"

# Create data directories
RUN mkdir -p /data/configs /data/logs /data/jobs

# Source code will be mounted as volume for hot reload

EXPOSE 8000

# Command will be overridden in docker-compose.dev.yml
CMD ["uvicorn", "harmony.api.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
