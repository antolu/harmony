# ==============================================================================
# REQUIRED: Database Configuration
# ==============================================================================
DATABASE_URL=postgresql://harmony:harmony@localhost:5432/harmony

# ==============================================================================
# REQUIRED: CORS Configuration
# ==============================================================================
# Comma-separated list of allowed origins. The API refuses to start if unset.
# Adjust to match your frontend URL(s).
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8080

# ==============================================================================
# SERVICE CONFIGURATION (Optional Overrides)
# ==============================================================================
# These variables override database-stored configurations. Use them for:
# - Development environments with specific requirements
# - Production deployments that manage config externally
# - Testing different service endpoints
#
# If not set, services use values from the database (configured via setup wizard)
# or fall back to Docker service name defaults.

# Elasticsearch Connection
# Default (Docker): http://elasticsearch:9200
# ES_HOST=http://localhost:9200

# Redis Connection
# Default (Docker): redis://redis:6379/0
# REDIS_URL=redis://localhost:6379/0

# Backend URL (auto-detected, rarely needs override)
# Default (Docker): http://harmony-api:8000
# HARMONY_BACKEND_URL=http://localhost:8000

# ==============================================================================
# Elasticsearch Configuration
# ==============================================================================
ES_INDEX_BASE_NAME=harmony
ES_LANGUAGES=en,fr
ES_CONFIG_FILE=es_config.yaml  # Optional: path to ES config YAML

# Multilingual Search Strategy
ES_MIN_RESULTS_BEFORE_FALLBACK=5
ES_LANGUAGE_DETECTION_CONFIDENCE_THRESHOLD=0.7

# ==============================================================================
# LLM Configuration
# ==============================================================================
# LLM API Keys (provide keys for the providers you use)
GEMINI_API_KEY=your_gemini_key_here
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# LLM Model Selection
# Supported models:
#   - Gemini: gemini/gemini-3-flash-preview, gemini/gemini-3-pro
#   - OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
#   - Anthropic: claude-3-5-sonnet-20241022, claude-3-opus-20240229
#   - Ollama: ollama_chat/llama3, ollama_chat/mistral (requires Ollama running locally)
LLM_MODEL=gemini/gemini-3-flash-preview

# Ollama Configuration (only needed for ollama_chat/* models)
OLLAMA_HOST=http://localhost:11434

# ==============================================================================
# API Server
# ==============================================================================
API_HOST=0.0.0.0
API_PORT=8000

# ==============================================================================
# Search Configuration
# ==============================================================================
SEARCH_RESULTS_SIZE=10

# Agentic Search Configuration
AGENTIC_MAX_REFINEMENT_ROUNDS=3
AGENTIC_MAX_QUERY_VARIANTS=4
AGENTIC_SEARCH_TOP_K=10
AGENTIC_MAX_SOURCES_RETURNED=10

# Document Cache (for runtime document fetching)
DOCUMENT_CACHE_ENABLED=true
DOCUMENT_CACHE_TTL=3600        # Cache TTL in seconds (1 hour)
DOCUMENT_CACHE_MAX_SIZE=1000   # Max number of cached documents

# ==============================================================================
# MCP Servers (Model Context Protocol)
# ==============================================================================
# JSON array of MCP server configurations
# Example with filesystem and GitHub servers:
# MCP_SERVERS='[
#   {
#     "name": "filesystem",
#     "command": "npx",
#     "args": ["-y", "@modelcontextprotocol/server-filesystem", "/path/to/allowed/directory"],
#     "env": {}
#   },
#   {
#     "name": "github",
#     "command": "npx",
#     "args": ["-y", "@modelcontextprotocol/server-github"],
#     "env": {
#       "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
#     }
#   }
# ]'

# GitHub token for MCP GitHub server (if used)
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here
