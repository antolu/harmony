# Elasticsearch
ES_HOST=http://localhost:9200
ES_INDEX=index

# Gemini API
GEMINI_API_KEY=123456

# LLM Configuration
LLM_MODEL=gemini/gemini-3-flash-preview

# Ollama (optional)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Search Configuration
SEARCH_RESULTS_SIZE=10

# FoA Configuration
FOA_MAX_REFINEMENT_ROUNDS=3
FOA_MAX_QUERY_VARIANTS=4
FOA_SEARCH_TOP_K=10
FOA_MAX_SOURCES_RETURNED=10
